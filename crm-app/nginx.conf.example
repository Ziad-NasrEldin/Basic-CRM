# Nginx Configuration for CRM App
# VPS-ready (RHEL/CentOS style): place at /etc/nginx/conf.d/crm.mavoid.com.conf
# Debian/Ubuntu alternative: /etc/nginx/sites-available/crm.mavoid.com + symlink to sites-enabled
# IMPORTANT: keep this file HTTP-only before first certificate issuance.
# Then run: certbot --nginx -d crm.mavoid.com
# Certbot will create/manage the HTTPS SSL directives automatically.

# HTTP server block (SSL handled separately by Certbot on the VPS)
server {
    listen 80;
    listen [::]:80;
    server_name crm.mavoid.com;

    # Security Headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Compression
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types text/plain text/css text/xml text/javascript application/json application/javascript application/xml+rss application/atom+xml image/svg+xml;

    # Client body size limit
    client_max_body_size 50M;

    # Proxy settings for Docker container
    location / {
        proxy_pass http://localhost:3092;
        proxy_http_version 1.1;
        
        # Required headers for WebSocket and upgrades
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        
        # Forward original request headers
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;
        proxy_set_header X-Forwarded-Port $server_port;
        
        # Timeouts
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
        
        # Buffering
        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
    }

    # Static files caching
    location ~* ^/(_next|public)/(.*)\.(js|css|png|jpg|jpeg|gif|ico|svg|webp|woff|woff2|ttf|eot)$ {
        proxy_pass http://localhost:3092;
        proxy_cache_valid 200 60d;
        proxy_cache_bypass $http_pragma $http_authorization;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # API routes caching
    location /api/ {
        proxy_pass http://localhost:3092;
        proxy_http_version 1.1;
        
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Don't cache API responses
        proxy_cache_bypass $http_pragma $http_authorization;
    }

    # Deny access to sensitive files
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Deny access to some files
    location ~ ~$ {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Access and error logs
    access_log /var/log/nginx/crm-app-access.log combined;
    error_log /var/log/nginx/crm-app-error.log;
}
